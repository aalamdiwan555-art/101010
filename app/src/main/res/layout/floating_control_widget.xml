<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlay_card"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#222222"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp">

        <!-- Drag Handle Indicator -->
        <ImageView
            android:id="@+id/iv_drag_handle"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="#FFD700"
            android:layout_marginEnd="6dp"
            android:contentDescription="Drag Handle" />

        <!-- Status Light indicator -->
        <View
            android:id="@+id/v_status_light"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@android:drawable/presence_online"
            android:backgroundTint="#FF4444"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dr. Clicker"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_overlay_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Engine Idled"
                android:textColor="#A0A0A0"
                android:textSize="9sp" />
        </LinearLayout>

        <!-- Small Quick Disable Button -->
        <ImageButton
            android:id="@+id/btn_quick_disable"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#FF4444"
            android:contentDescription="Stop Engine" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
